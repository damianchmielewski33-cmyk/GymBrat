# Copy to .env.local and fill in values.

# Turso / libsql (Vercel: set TURSO_DATABASE_URL + TURSO_AUTH_TOKEN)
# Lokalnie: ścieżka względem katalogu projektu (npm run dev / db:push)
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# NextAuth — wymagane w produkcji; lokalnie możesz wygenerować:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))  # PowerShell
#   openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Optional: Fitatu-compatible REST proxy (see services/fitatu.ts)
# FITATU_API_BASE_URL=https://your-proxy.example.com/v1
# FITATU_API_KEY=

# Optional: future AI provider
# AI_API_KEY=
# AI_MODEL= (optional, provider-specific)
