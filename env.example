# Copy to .env.local and fill in values.

# Turso / libsql (Vercel: set TURSO_DATABASE_URL + TURSO_AUTH_TOKEN)
# Lokalnie: ścieżka względem katalogu projektu (npm run dev / db:push)
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# NextAuth — wymagane w produkcji; lokalnie możesz wygenerować:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))  # PowerShell
#   openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Email verification (registration code)
# Recommended provider: Resend (works great on Vercel).
# Configure:
# - RESEND_API_KEY
# - EMAIL_FROM (must be a verified sender/domain in Resend)
# - optional EMAIL_REPLY_TO
# - EMAIL_CODE_SECRET (pepper for hashing codes; can reuse AUTH_SECRET but better separate)
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
EMAIL_CODE_SECRET=

# Ten sam kalendarz co wpisy posiłków / Start (domyślnie Europa/Warszawa).
# Ustaw obie zmienne na produkcji, żeby serwer i przeglądarka liczyły ten sam „dzisiaj”.
# CALENDAR_TIMEZONE=Europe/Warsaw
# NEXT_PUBLIC_CALENDAR_TIMEZONE=Europe/Warsaw

# Optional: most Fitatu (lokalnie: npm run dev w katalogu fitatu-bridge)
# FITATU_API_BASE_URL=http://localhost:8787
# FITATU_API_KEY=
# Most udostępnia POST /auth/login oraz GET /diary/YYYY-MM-DD — szczegóły: fitatu-bridge/README.md

# Optional: future AI provider
# AI_API_KEY=
# AI_MODEL= (optional, provider-specific)
