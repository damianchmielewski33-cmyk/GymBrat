# Copy to .env.local and fill in values.

# Turso / libsql (Vercel: set TURSO_DATABASE_URL + TURSO_AUTH_TOKEN)
# Lokalnie: ścieżka względem katalogu projektu (npm run dev / db:push)
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# NextAuth — wymagane w produkcji; lokalnie możesz wygenerować:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))  # PowerShell
#   openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Szyfrowanie pól w DB (token Fitatu, zdjęcia raportów) — klucz AES-256: 32 bajty jako base64 lub hex.
# Wygeneruj: Node: require('crypto').randomBytes(32).toString('base64')
APP_ENCRYPTION_KEY=

# Admin panel: PIN wymagany na produkcji (ustaw w środowisku).
ADMIN_PIN=

# Adresy email kont administratorów (CSV, bez spacji — dopasowanie case-insensitive).
# Po pierwszym logowaniu rola `admin` jest zapisywana w bazie.
ADMIN_EMAILS=

# Jednorazowy token POST /api/admin/bootstrap (CSRF + sesja) — gdy w bazie nie ma jeszcze admina.
ADMIN_BOOTSTRAP_TOKEN=

# Cron / maintenance: sekret do wywołania sprzątania bazy (POST /api/cron/cleanup).
CRON_SECRET=

# Rate limiting rozproszony (Upstash Redis REST) — opcjonalnie; bez tego limit jest in-process.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Retencja danych (dni) – pomaga utrzymać limity darmowej bazy Turso.
# Analytics (zwykle największy przyrost):
RETENTION_PAGE_VIEWS_DAYS=30
RETENTION_ACTIVITY_LOG_DAYS=90
# Kody e-mail (przeterminowane/zużyte):
RETENTION_EMAIL_CODES_DAYS=14
# Zdjęcia raportów (UWAGA: realne dane biometryczne). Rekomendowana retencja B2C:
RETENTION_BODY_REPORT_PHOTOS_DAYS=365

# --- Email: weryfikacja rejestracji (Nodemailer + SMTP) ---
# Użyj konta Gmail lub Outlook (Microsoft) albo innego dostawcy SMTP.
#
# Gmail:
#   1) Włącz weryfikację dwuetapową na koncie Google.
#   2) Wygeneruj „Hasło do aplikacji” (App password): Google Account → Security → App passwords.
#   3) SMTP_USER = pełny adres Gmail, SMTP_PASS = wygenerowane hasło aplikacji (nie zwykłe hasło).
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#
# Outlook.com / Hotmail (osobiste konto Microsoft):
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   Czasem wymagane jest hasło aplikacji jeśli masz MFA — Microsoft Account → Security.
#
# Microsoft 365 / Outlook firmowy (często):
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#
# EMAIL_FROM — opcjonalnie; jeśli puste, jako nadawca używany jest SMTP_USER.
# Format: "GymBrat <twoj@email.com>" lub sam adres.
# EMAIL_REPLY_TO — opcjonalny adres „odpowiedz do”.
#
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_REPLY_TO=
# Sekret do hashowania kodów (możesz użyć osobnego od AUTH_SECRET):
EMAIL_CODE_SECRET=

# Ten sam kalendarz co wpisy posiłków / Start (domyślnie Europa/Warszawa).
# Ustaw obie zmienne na produkcji, żeby serwer i przeglądarka liczyły ten sam „dzisiaj”.
# CALENDAR_TIMEZONE=Europe/Warsaw
# NEXT_PUBLIC_CALENDAR_TIMEZONE=Europe/Warsaw

# Optional: most Fitatu (lokalnie: npm run dev w katalogu fitatu-bridge)
# FITATU_API_BASE_URL=http://localhost:8787
# FITATU_API_KEY=
# Most udostępnia POST /auth/login oraz GET /diary/YYYY-MM-DD — szczegóły: fitatu-bridge/README.md

# Sentry (opcjonalnie — błędy runtime)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.05

# Optional: AI
#
# 1) Gemini (cloud; may require billing/quota)
# AI_PROVIDER=gemini
# AI_API_KEY=
# REST :generateContent (czat, briefing, plany) — domyślnie gemini-2.5-flash w kodzie, jeśli nie ustawisz AI_MODEL.
# AI_MODEL=gemini-2.5-flash
#
# NIE ustawiaj tu modeli „Native Dialog Audio” / preview audio (np. gemini-2.5-flash-native-audio-preview-*):
# to Gemini Live API (WebSocket + audio), inny protokół niż ten backend — zob. README sekcja AI.
#
# 2) Self-hosted (FREE): Ollama + AI relay server (recommended)
# - Start `docker compose up -d` (see docker-compose.yml)
# - Set a strong token for the relay
# AI_PROVIDER=ollama
# AI_API_BASE_URL=http://localhost:11435
# AI_API_KEY=change_me_strong_token
# AI_MODEL=llama3.1:8b
#
# (Advanced) If you run Ollama directly (no relay), you can point to it:
# AI_PROVIDER=ollama
# AI_API_BASE_URL=http://127.0.0.1:11434
# AI_MODEL=llama3.1:8b
