# Port serwera mostu (GymBrat: FITATU_API_BASE_URL=http://localhost:8787)
PORT=8787

# mock | forward | file
# - mock: demo logowanie + stałe dane dziennika (domyślnie)
# - forward: przekazuje żądania na FITATU_UPSTREAM_* (wypełnij po przechwyceniu ruchu z aplikacji)
# - file: czyta pliki JSON z FITATU_EXPORT_DIR (np. eksport skryptem)
BRIDGE_MODE=mock

# Opcjonalnie: dozwolone źródła CORS (oddzielone przecinkami), np. http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# --- tryb forward (przykład — adresy MUSISZ uzupełnić sam, patrz README w tym katalogu) ---
# FITATU_UPSTREAM_LOGIN_URL=https://twoj-przechwycony-host/auth
# FITATU_UPSTREAM_DIARY_URL_TEMPLATE=https://twoj-przechwycony-host/diary/{{date}}
# Opcjonalnie dodatkowe nagłówki do upstreamu (JSON): {"X-App-Version":"1.0"}
# FITATU_UPSTREAM_EXTRA_HEADERS_JSON=

# --- tryb file ---
# FITATU_EXPORT_DIR=./export-data
# Plik: {FITATU_EXPORT_DIR}/diary-YYYY-MM-DD.json w kształcie jak poniżej (README).
